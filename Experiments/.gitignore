exp01_mandelbrot_fit/data/outputs/
exp02_beta_calibration/data/domain_corpora/
exp03_gap_signal/data/outputs/
shared/rank_tables/

# Python cache
__pycache__/
*.pyc

# Jupyter checkpoints
.ipynb_checkpoints/

# Large JSON results (regeneratable)
**/gap_results_full_*.json

# Tier 2 experiment data (regeneratable)
exp04_halueval/data/
exp04_halueval/results/
